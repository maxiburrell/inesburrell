# Copy to .env.local for development. Set all of these in Vercel for production.

# Sanity (public — safe to expose)
NEXT_PUBLIC_SANITY_PROJECT_ID=9f4iigah
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-07-01

# Site — production value: https://inesburrell.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Contact form (Resend)
RESEND_API_KEY=
CONTACT_TO_EMAIL=info@inesburrell.com
CONTACT_FROM_EMAIL=website@inesburrell.com

# Sanity webhook secret for /api/revalidate — any long random string,
# must match the secret configured on the webhook in sanity.io/manage
SANITY_REVALIDATE_SECRET=
